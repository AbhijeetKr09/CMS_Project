generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model session {
  sid    String   @id @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
}

model Article {
  id               String   @id @default(uuid())
  slug             String?  @unique
  title            String
  timestampDate    DateTime
  readTime         String?
  mainImage        String?
  shortDescription String?
  body             String?
  tags             String[]
  type             String?
  views            Int      @default(0)

  // relations
  images           ArticleImage[]
  keyInsights      ArticleKeyInsight[]
  relatedNews      ArticleRelatedNews[]             @relation("ArticleRelatedNews")
  relatedArticles  ArticleRelatedNews[]             @relation("RelatedArticles")
  comments         Comment[]
  userHistory      UserHistory[]
  savedBy          SavedArticle[]

  // Back-relations from StagedArticle (for editors linking a draft to published articles)
  stagedRelated1   StagedArticle[]                 @relation("StagedRelated1")
  stagedRelated2   StagedArticle[]                 @relation("StagedRelated2")
  stagedRelated3   StagedArticle[]                 @relation("StagedRelated3")
  stagedRelated4   StagedArticle[]                 @relation("StagedRelated4")

  @@map("articles")
}

model ArticleImage {
  id        Int     @id @default(autoincrement())
  src       String
  alt       String?
  caption   String?
  link      String?
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("article_images")
}


model ArticleKeyInsight {
  id          Int     @id @default(autoincrement())
  insightText String
  articleId   String
  article     Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("article_key_insights")
}

model ArticleRelatedNews {
  id               Int      @id @default(autoincrement())
  articleId        String
  article          Article  @relation("ArticleRelatedNews", fields: [articleId], references: [id], onDelete: Cascade)

  // The internal Avionyz article that is related
  relatedArticleId String
  relatedArticle   Article  @relation("RelatedArticles", fields: [relatedArticleId], references: [id], onDelete: Cascade)

  @@map("article_related_news")
}

model Comment {
  id        Int      @id @default(autoincrement())
  text      String
  createdAt DateTime @default(now())
  articleId String
  userId    String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Airline {
  id      Int             @id @default(autoincrement())
  name    String          @unique
  reviews FlightReview[]

  @@map("airlines")
}

model FlightReview {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())

  airlineId  Int
  airline    Airline  @relation(fields: [airlineId], references: [id])

  rating     Int
  experience String?

  @@map("flight_reviews")
}

model Event {
  id              String   @id @default(uuid())
  eventName       String
  eventLink       String
  venue           String
  onlineOrOffline String
  freeOrPaid      String
  date            DateTime
  time            String
  eventType       String
  region          String
  image           String

  // New columns for map functionality
  lat         Float
  lng         Float
  country     String
  description String?
  organizedBy String?
  images      String[] // Array of strings for multiple images
  savedBy     SavedEvent[]

  @@map("events")
}

model Media {
  id          String    @id @default(uuid())
  type        String // video, image, podcast, magazine, advertisement
  title       String
  description String?
  url         String? // videoUrl, pdfUrl, link
  thumbnail   String? // thumbnail, imageUrl, coverImage
  tags        String[]
  date        DateTime?
  adId        String?
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])

  views     Int @default(0)
  downloads Int @default(0)

  savedBy SavedMedia[]
  likes   MediaLike[]

  @@map("media")
}

model User {
  id           String   @id // Cognito Sub
  email        String   @unique
  name         String?
  occupation   String?
  phoneNumber  String?
  profileImage String? // URL to S3
  coverImage   String? // URL to S3
  bio          String?
  isExpert     Boolean  @default(false)
  createdAt    DateTime @default(now())
  preferences  String[]

  // Relations
  uploads   Media[]
  comments  Comment[]
  history   UserHistory[]
  feedPosts FeedPost[]
  feedLikes FeedLike[]

  usersLiked MediaLike[]
  savedMedia SavedMedia[]
  savedEvents SavedEvent[]
  savedArticles SavedArticle[]
  notifications Notification[]
  pinnedInsights PinnedInsight[]

  followers UserFollow[] @relation("following")
  following UserFollow[] @relation("follower")

  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  @@map("users")
}

model SavedMedia {
  id        Int      @id @default(autoincrement())
  userId    String
  mediaId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId])
  @@map("saved_media")
}

model MediaLike {
  id        Int      @id @default(autoincrement())
  userId    String
  mediaId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId])
  @@map("media_likes")
}

model UserHistory {
  id        Int      @id @default(autoincrement())
  userId    String
  articleId String
  visitedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("user_history")
}

model FeedCategory {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  posts       FeedPost[]

  @@map("feed_categories")
}

model FeedPost {
  id         String        @id @default(uuid())
  title      String? // Null for replies
  content    String
  images     String[] // S3 Keys
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String?
  category   FeedCategory? @relation(fields: [categoryId], references: [id])

  // Threading
  parentId String?
  parent   FeedPost?  @relation("ThreadHistory", fields: [parentId], references: [id], onDelete: Cascade)
  replies  FeedPost[] @relation("ThreadHistory")

  likes FeedLike[]
  tags  String[] // Array of strings for trending tags

  @@map("feed_posts")
}

model FeedLike {
  id        Int      @id @default(autoincrement())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@map("feed_likes")
}

model AnalyticalArticle {
  id                 String   @id @default(uuid())
  slug               String?  @unique
  title              String
  headingDescription String?
  readTime           String?
  mainImage          String?
  shortDescription   String?
  body               String?
  tags               String[]

  // Specific to AnalyticalArticle
  isPremium Boolean @default(false)
  dataKey String?

  // Flexible JSON fields for structure content
  tableOfContents Json?
  faq             Json?
  advertisement   Json?

  images String[] // S3 keys or URLs

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("analytical_articles")
}

model UserFollow {
  id          Int      @id @default(autoincrement())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("user_follows")
}

model Message {
  id         String   @id @default(uuid())
  content    String
  senderId   String
  receiverId String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  deletedBySender   Boolean @default(false)
  deletedByReceiver Boolean @default(false)

  @@index([senderId, receiverId])
  @@index([createdAt])
  @@map("messages")
}

model Expert {
  id        String   @id @default(uuid())
  name      String
  role      String
  company   String
  image     String? // S3 key or URL
  quote     String
  highlight String? // e.g. "Expert of the Week"
  url       String? // Link to expert's profile or company
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("experts")
}

model SocialTrend {
  id        String   @id @default(uuid())
  platform  String   // linkedin, twitter, youtube
  content   String?  // Text content or title
  url       String   // Link to the post/video
  imageUrl  String?  // Thumbnail or image
  author    String?  // Channel name or user handle
  authorImage String? // Profile pic or channel icon
  date      DateTime @default(now()) // Display date
  likes     String?   // "25k", "1.2M" etc.
  comments  String?
  shares    String?
  isActive  Boolean  @default(true)
  
  @@map("social_trends")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  text      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("notifications")
}

model SavedEvent {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("saved_events")
}

model PinnedInsight {
  id        String   @id @default(uuid())
  userId    String
  title     String
  type      String   // 'chart' or 'bar'
  data      Json?    
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("pinned_insights")
}

model SavedArticle {
  id        String   @id @default(uuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@map("saved_articles")
}

model CmsUser {
  id                String          @id @default(uuid())
  email             String          @unique
  passwordHash      String
  name              String
  bio               String?         // About the journalist
  role              CmsRole         @default(JOURNALIST)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  reviewedArticles  StagedArticle[] @relation("ReviewedBy")
  submittedArticles StagedArticle[] @relation("SubmittedBy")
  assignedArticles  StagedArticle[] @relation("AssignedTo")

  @@map("cms_users")
}

model StagedArticle {
  id                 String                  @id @default(uuid())
  slug               String?                 @unique
  title              String                  @default("")
  body               String?
  shortDescription   String?
  mainImage          String?
  readTime           String?
  tags               String[]
  type               String?
  status             StagedArticleStatus     @default(DRAFT)
  editorNote         String?
  submittedById      String
  reviewedById       String?
  assignedToId       String?                 // journalist this is assigned to
  recalledFromId     String?                 // original published article id (for recalls)
  publishedArticleId String?                 @unique
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  submittedAt        DateTime?
  reviewedAt         DateTime?
  assignedAt         DateTime?

  // Related internal article IDs (up to 4) — proper FK relations to Article
  // onDelete: SetNull so deleting a published article doesn't destroy the staged draft
  relatedArticle1Id  String?
  relatedArticle1    Article?                @relation("StagedRelated1", fields: [relatedArticle1Id], references: [id], onDelete: SetNull)
  relatedArticle2Id  String?
  relatedArticle2    Article?                @relation("StagedRelated2", fields: [relatedArticle2Id], references: [id], onDelete: SetNull)
  relatedArticle3Id  String?
  relatedArticle3    Article?                @relation("StagedRelated3", fields: [relatedArticle3Id], references: [id], onDelete: SetNull)
  relatedArticle4Id  String?
  relatedArticle4    Article?                @relation("StagedRelated4", fields: [relatedArticle4Id], references: [id], onDelete: SetNull)

  images             StagedArticleImage[]
  keyInsights        StagedArticleKeyInsight[]

  reviewedBy         CmsUser?                @relation("ReviewedBy", fields: [reviewedById], references: [id])
  submittedBy        CmsUser                 @relation("SubmittedBy", fields: [submittedById], references: [id])
  assignedTo         CmsUser?                @relation("AssignedTo", fields: [assignedToId], references: [id])

  @@map("staged_articles")
}

model StagedArticleImage {
  id              Int           @id @default(autoincrement())
  src             String
  alt             String?
  caption         String?
  link            String?
  stagedArticleId String
  stagedArticle   StagedArticle @relation(fields: [stagedArticleId], references: [id], onDelete: Cascade)

  @@map("staged_article_images")
}


model StagedArticleKeyInsight {
  id              Int           @id @default(autoincrement())
  insightText     String
  stagedArticleId String
  stagedArticle   StagedArticle @relation(fields: [stagedArticleId], references: [id], onDelete: Cascade)

  @@map("staged_article_key_insights")
}



enum CmsRole {
  JOURNALIST
  EDITOR
  ADMIN
}

enum StagedArticleStatus {
  DRAFT
  SUBMITTED
  NEEDS_CHANGES
  PUBLISHED
}

